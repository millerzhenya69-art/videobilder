# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USER_IDS=your_telegram_user_id_here

# Gemini AI (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.9

# Brand
BRAND_NAME=AtlantaVPN
BRAND_URL=https://atlantavpn.net
CTA_TEXT=Ссылка в шапке профиля

# Video
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
FPS=30
MIN_DURATION_SECONDS=15
MAX_DURATION_SECONDS=25

# TTS (edge + gTTS fallback — работает без ключа)
DEFAULT_TTS_ENGINE=edge
DEFAULT_TTS_VOICE=ru-RU-DmitryNeural
DEFAULT_VOICE_GENDER=male
SPEECH_RATE=+5%
SPEECH_PITCH=+0Hz

# Pexels (опционально, https://www.pexels.com/api/)
# Без ключа — градиентные фоны. С ключом — реальные видео.
PEXELS_API_KEY=

# Пути (оставь как есть для Railway)
CACHE_DIR=cache
LOGS_DIR=logs
ASSETS_DIR=assets
SQLITE_PATH=cache/bot.sqlite3
